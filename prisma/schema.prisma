// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── USERS ──────────────────────────────────────────────────────
model User {
  id          String   @id @default(uuid())
  name        String
  division    Division
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  securityReports SecurityReport[]
  hseReports      HSEReport[]

  @@map("users")
}

enum Division {
  SECURITY
  HSE
}

// ─── ADMIN ──────────────────────────────────────────────────────
model Admin {
  id        String    @id @default(uuid())
  username  String    @unique
  password  String
  role      AdminRole @default(VIEWER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN
  VIEWER
}

// ─── PATROL AREAS ────────────────────────────────────────────────
model PatrolArea {
  id                  String   @id @default(uuid())
  name                String
  code                String   @unique
  isActive            Boolean  @default(true)
  referenceImageUrl1  String?  @db.Text
  referenceImageUrl2  String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sections         AreaSection[]
  reportAreaVisits ReportAreaVisit[]

  @@map("patrol_areas")
}

model AreaSection {
  id                 String  @id @default(uuid())
  areaId             String
  order              Int
  name               String
  description        String? @db.Text
  referenceImageUrl1 String? @db.Text
  referenceImageUrl2 String? @db.Text

  area           PatrolArea     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  sectionEntries SectionEntry[]

  @@map("area_sections")
}

// ─── SECURITY REPORTS ────────────────────────────────────────────
model SecurityReport {
  id                   String    @id @default(uuid())
  userId               String
  patrolDate           String
  patrolTime           String
  formOpenedAt         DateTime?
  latitude             Float?
  longitude            Float?
  selfiePhotoUrl       String?   @db.Text
  selfiePhotoTimestamp DateTime?
  createdAt            DateTime  @default(now())

  user       User              @relation(fields: [userId], references: [id])
  areaVisits ReportAreaVisit[]

  @@map("security_reports")
}

model ReportAreaVisit {
  id       String @id @default(uuid())
  reportId String
  areaId   String
  order    Int

  report         SecurityReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  area           PatrolArea     @relation(fields: [areaId], references: [id])
  sectionEntries SectionEntry[]

  @@map("report_area_visits")
}

model SectionEntry {
  id            String @id @default(uuid())
  areaVisitId   String
  areaSectionId String

  areaVisit   ReportAreaVisit  @relation(fields: [areaVisitId], references: [id], onDelete: Cascade)
  areaSection AreaSection      @relation(fields: [areaSectionId], references: [id])
  findings    SectionFinding[]

  @@map("section_entries")
}

// Each section can have multiple findings (or one "no finding" entry)
model SectionFinding {
  id                 String      @id @default(uuid())
  sectionEntryId     String
  status             CheckStatus
  findingDescription String?     @db.Text
  photoUrl           String      @db.Text
  photoTimestamp     DateTime
  photoLatitude      Float?
  photoLongitude     Float?
  order              Int         @default(0)

  sectionEntry SectionEntry @relation(fields: [sectionEntryId], references: [id], onDelete: Cascade)

  @@map("section_findings")
}

enum CheckStatus {
  NO_FINDING
  FINDING
}

// ─── HSE REPORTS ─────────────────────────────────────────────────
model HSEReport {
  id                  String   @id @default(uuid())
  userId              String
  visitDate           String
  visitTime           String
  latitude            Float?
  longitude           Float?
  hseSignatureUrl     String?  @db.Text
  witnessSignatureUrl String?  @db.Text
  createdAt           DateTime @default(now())

  user       User           @relation(fields: [userId], references: [id])
  areaVisits HSEAreaVisit[]

  @@map("hse_reports")
}

model HSEAreaVisit {
  id                       String   @id @default(uuid())
  reportId                 String
  areaName                 String
  workActivities           String   @db.Text
  hazardDescription        String   @db.Text
  socializationDescription String   @db.Text
  evidencePhotoUrl         String   @db.Text
  evidencePhotoTimestamp   DateTime
  evidencePhotoLatitude    Float?
  evidencePhotoLongitude   Float?

  report  HSEReport   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  hazards HSEHazard[]

  @@map("hse_area_visits")
}

model HSEHazard {
  id          String     @id @default(uuid())
  areaVisitId String
  hazardType  HazardType

  areaVisit HSEAreaVisit @relation(fields: [areaVisitId], references: [id], onDelete: Cascade)

  @@map("hse_hazards")
}

enum HazardType {
  TERJATUH
  TERGELINCIR
  TERKENA_BENDA_TAJAM
  TERBAKAR
  TERSENGAT_LISTRIK
  TERTIMPA_BENDA
  TERHIRUP_GAS
  KONTAK_BAHAN_KIMIA
  KEBISINGAN
  KELELAHAN
  LAINNYA
}

// ─── UPLOADED FILES ───────────────────────────────────────────────
model UploadedFile {
  id           String   @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  createdAt    DateTime @default(now())

  @@map("uploaded_files")
}
